	(text "DDI/TCP functions are defined by the BIOS source code, \nCannot be changed in BIOS settings.\n\nBefore starting design, you should choose one of\nthe available BIOS configurations on:\nhttps://github.com/LattePandaTeam/LattePanda-Mu\n\nThe default functions are defined as follows:\n\n- DDIA: eDP 1.4b (the 40Pin connector on the Mu)\n\n- DDIB: HDMI 2.0\n\n- TCP0: HDMI 2.0\n\n- TCP1: USB TypeC (need external PD controller)"
		(exclude_from_sim no)
		(at 33.782 190.754 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "5c7bf6b7-456f-4c44-ae00-5b48c2a7bab8")
	)
	(text "should be fine"
		(exclude_from_sim no)
		(at 610.87 121.158 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "5d1779c5-e1bf-44d6-ac3d-9a29ceb2b99a")
	)
	(text "the 4 hsio B would usually be used for pci x4 but we won't use it"
