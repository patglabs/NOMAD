	(text "HDMI"
		(exclude_from_sim no)
		(at 472.186 189.23 0)
		(effects
			(font
				(size 12.7 12.7)
			)
		)
		(uuid "52ccf451-6aed-47da-bf48-e2a75b6a8cf6")
	)
	(text "DDI/TCP functions are defined by the BIOS source code, \nCannot be changed in BIOS settings.\n\nBefore starting design, you should choose one of\nthe available BIOS configurations on:\nhttps://github.com/LattePandaTeam/LattePanda-Mu\n\nThe default functions are defined as follows:\n\n- DDIA: eDP 1.4b (the 40Pin connector on the Mu)\n\n- DDIB: HDMI 2.0\n\n- TCP0: HDMI 2.0\n\n- TCP1: USB TypeC (need external PD controller)"
		(exclude_from_sim no)
		(at 33.782 190.754 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "5c7bf6b7-456f-4c44-ae00-5b48c2a7bab8")
	)
	(text "should be fine"
		(exclude_from_sim no)
		(at 610.87 121.158 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "5d1779c5-e1bf-44d6-ac3d-9a29ceb2b99a")
	)
	(text "the 4 hsio B would usually be used for pci x4 but we won't use it"
		(exclude_from_sim no)
		(at 163.322 127 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "6e4cf13b-7c2b-41e1-840e-fd31b212b9ce")
	)
	(text "usb 3 seperated\n"
		(exclude_from_sim no)
		(at 713.232 78.994 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "cb316aa6-b9fc-4b7d-a917-61fab26bdf58")
	)
	(text "they have internal pull up resistors"
		(exclude_from_sim no)
		(at 336.55 213.106 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "d3240c2b-f153-4f8a-9389-85e860d96bff")
	)
	(text "usb 3 seperated\n"
		(exclude_from_sim no)
		(at 714.248 123.952 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "dc5d1f1d-198a-4481-9d2c-62e4f3a02967")
	)
	(text "HSIO functions are defined by the BIOS source code, \nCannot be changed in BIOS settings.\n\nBefore starting design, you should choose one of\nthe available BIOS configurations on:\nhttps://github.com/LattePandaTeam/LattePanda-Mu\nOr contact techsupport for custom your BIOS\n\nThe default functions are defined as follows:\n\n- HSIO0: USB3.2 10Gbps\n- HSIO1: USB3.2 10Gbps\n- HSIO2: PCIe 3.0 x1\n- HSIO3: PCIe 3.0 x1\n\n- HSIO8: PCIe 3.0 x4 (Lane 0)\n- HSIO9: PCIe 3.0 x4 (Lane 1)\n- HSIO10: PCIe 3.0 x4 (Lane 2)\n- HSIO11: PCIe 3.0 x4 (Lane 3)\n\n- HSIO6: PCIe 3.0 x1"
		(exclude_from_sim no)
		(at 33.782 63.754 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "dd64e827-0a69-4a0d-a1b7-a1c3add551d8")
	)
	(text "USB2_P6 is reserved for TypeC PD Controller\nONLY"
		(exclude_from_sim no)
		(at 309.372 113.284 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "eacdf38b-4002-4ac4-aa47-6d259be2023c")
	)
	(text "Sleeping State Signal\n\n- SLS_S0: \n  - S0 (Working): HIGH\n  - S3 (Slpeeping): LOW\n  - S4 (Hibernation): LOW\n  - S5 (Soft Off): LOW\n- SLS_S3:\n  - S0 (Working): HIGH\n  - S3 (Slpeeping): HIGH\n  - S4 (Hibernation): LOW\n  - S5 (Soft Off): LOW"
		(exclude_from_sim no)
		(at 148.844 31.75 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "ee5820bd-93fd-41c3-a7f2-0e3149beaeb9")
	)
	(text "but before there was no gnd"
		(exclude_from_sim no)
		(at 612.14 122.936 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "ee6e1655-f97a-4a4e-9b99-63f865efbe94")
	)
	(text "~{CLKREQ} is reserved for PCIe ASPM L1s\nUnless the device clearly supports it, pull it down to enhance compatibility"
